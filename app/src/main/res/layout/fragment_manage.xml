<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_manage_gradient"
    tools:context=".ManageFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 🔷 Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manage"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:fontFamily="@font/lexend_bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Control your academic system"
                    android:textSize="14sp"
                    android:textColor="#A0A8C0"
                    android:fontFamily="@font/lexend"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/manage_profile_pic"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/circle_bg"
                android:scaleType="centerCrop"
                android:src="@drawable/baseline_account_circle_24"
                android:padding="2dp"/>
        </LinearLayout>


        <!-- 🔷 Buttons Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="30dp">

            <!-- Add Students -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddStudents"
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:layout_marginBottom="18dp"
                android:padding="20dp"
                android:text="Add Students"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/lexend"
                android:gravity="start|center_vertical"
                android:backgroundTint="#1A2238"
                app:cornerRadius="22dp"
                app:strokeColor="#26304D"
                app:strokeWidth="1dp"
                app:elevation="8dp"
                app:icon="@drawable/baseline_person_24"
                app:iconTint="#6C8CFF"
                app:iconPadding="16dp"
                app:iconSize="30dp"
                app:iconGravity="textStart" />

            <!-- Add Batches -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddBatches"
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:padding="20dp"
                app:iconSize="30dp"
                android:text="Add Batches"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/lexend"
                android:gravity="start|center_vertical"
                android:backgroundTint="#1A2238"
                app:cornerRadius="22dp"
                app:strokeColor="#26304D"
                app:strokeWidth="1dp"
                app:elevation="8dp"
                app:icon="@drawable/baseline_group_24"
                app:iconTint="#34A853"
                app:iconPadding="16dp"
                app:iconGravity="textStart"
                android:layout_marginBottom="18dp"/>
            <!-- Add Subjects -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddSubjects"
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:padding="20dp"
                android:text="Add Subjects"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/lexend"
                android:gravity="start|center_vertical"
                android:backgroundTint="#1A2238"
                app:cornerRadius="22dp"
                app:strokeColor="#26304D"
                app:strokeWidth="1dp"
                app:elevation="8dp"
                app:icon="@drawable/outline_book_24"
                app:iconSize="30dp"
                app:iconTint="#F4B400"
                app:iconPadding="16dp"
                app:iconGravity="textStart" />

        </LinearLayout>

    </LinearLayout>

    <!-- Version -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TEACHSYNC v1.0.0"
        android:textSize="11sp"
        android:textColor="#66709A"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="50dp"
        android:fontFamily="@font/lexend"/>

</FrameLayout>