<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:layout_marginHorizontal="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_date_card"
        android:padding="14dp">

        <!-- Row: Topic + Status badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTopic"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

            <!-- Status badges -->
            <TextView
                android:id="@+id/tvOnGoing"
                android:text="● On Going"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="#CC2E7D32"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvStatusBadge"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvBatch"
            android:textColor="#9FA8DA"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvClassTime"
            android:textColor="#4CAF50"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Row: Class number + Remaining -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvMonthlyNumber"
                android:textColor="#5C6BC0"
                android:textSize="13sp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

            <!-- Remaining classes chip -->
            <TextView
                android:id="@+id/tvRemaining"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#993949AB"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvExtra"
            android:text="Extra Class"
            android:textColor="#FF5252"
            android:textSize="12sp"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- CONFIRMATION OVERLAY (Shown after class time ends if still "scheduled") -->
    <LinearLayout
        android:id="@+id/layoutConfirmationOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E60B1020"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Was this class taken?"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnMarkCompleted"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Done"
                android:textSize="10sp"
                android:backgroundTint="#4CAF50"
                android:layout_marginEnd="4dp"
                android:paddingHorizontal="8dp"
                android:minHeight="0dp"
                android:minWidth="0dp"/>

            <Button
                android:id="@+id/btnMarkPostponed"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Postpone"
                android:textSize="10sp"
                android:backgroundTint="#F44336"
                android:layout_marginEnd="4dp"
                android:paddingHorizontal="8dp"
                android:minHeight="0dp"
                android:minWidth="0dp"/>

            <Button
                android:id="@+id/btnMarkRescheduled"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Reschedule"
                android:textSize="10sp"
                android:backgroundTint="#FF9800"
                android:paddingHorizontal="8dp"
                android:minHeight="0dp"
                android:minWidth="0dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- STATUS OVERLAY (Final state: Completed / Postponed / Rescheduled) -->
    <LinearLayout
        android:id="@+id/layoutCompletedOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B30B1020"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvOverlayStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMPLETED"
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:textSize="12sp"
            android:background="@drawable/bg_completed_badge"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"/>

    </LinearLayout>

</FrameLayout>
