<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:layout_marginHorizontal="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_date_card"
        android:padding="14dp">

        <!-- Row: Topic + ON GOING badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTopic"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

            <!-- ON GOING badge — shown only during class time window -->
            <TextView
                android:id="@+id/tvOnGoing"
                android:text="● On Going"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="#CC2E7D32"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvBatch"
            android:textColor="#9FA8DA"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvClassTime"
            android:textColor="#4CAF50"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Row: Class number + Remaining -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvMonthlyNumber"
                android:textColor="#5C6BC0"
                android:textSize="13sp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

            <!-- Remaining classes chip -->
            <TextView
                android:id="@+id/tvRemaining"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#993949AB"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvExtra"
            android:text="Extra Class"
            android:textColor="#FF5252"
            android:textSize="12sp"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- COMPLETED OVERLAY -->
    <LinearLayout
        android:id="@+id/layoutCompletedOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B30B1020"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMPLETED"
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:textSize="12sp"
            android:background="@drawable/bg_completed_badge"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"/>

    </LinearLayout>

</FrameLayout>
