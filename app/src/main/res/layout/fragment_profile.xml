<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1020"
    tools:context=".ProfileFragment">

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        >

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/profile_settingsBtn"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/item_row_click"
                android:contentDescription="TODO"
                android:src="@drawable/baseline_settings_24"
                app:tint="#9AA4C7" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/lexend_bold"
                android:gravity="center"
                android:text="User Profile"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <ImageView
                android:id="@+id/profile_logoutBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/item_row_click"
                android:src="@drawable/baseline_logout_24"
                app:tint="#FF5A5A" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Avatar -->
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center">

                    <ImageView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:src="@drawable/baseline_person_24"
                        android:scaleType="centerCrop"
                        android:background="@drawable/circle_bg"
                        android:padding="4dp" />

                    <View
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/online_dot" />
                </FrameLayout>

                <TextView
                    android:id="@+id/profile_fullname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/lexend_bold"
                    android:text="Alex Thompson"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/profile_joindate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="24dp"
                    android:fontFamily="@font/lexend"
                    android:text="Joined Sep-2023"
                    android:textColor="#9AA4C7"
                    android:textSize="13sp" />

                <!-- Options -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="@font/lexend"
                    android:text="ACCOUNT SETTINGS"
                    android:textAllCaps="true"
                    android:textColor="#7E89B0"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <include android:id="@+id/profile_option" layout="@layout/item_profile_option" />
                <include android:id="@+id/profile_security" layout="@layout/item_profile_option_security" />
                <include android:id="@+id/profile_notification" layout="@layout/item_profile_option_notification" />

                <!-- Premium Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="#1A2140">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/outline_star_24"
                            app:tint="#7B8CFF" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Remove Ads"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5.00$"
                                android:textColor="#9AA4C7"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <Button
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Buy Now"
                            android:textAllCaps="false"
                            android:backgroundTint="#5667FF"
                            android:textColor="#FFFFFF" />
                    </LinearLayout>

                </androidx.cardview.widget.CardView>


                <!-- HELP & SUPPORT -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="@font/lexend"
                    android:text="HELP &amp; SUPPORT"
                    android:textAllCaps="true"
                    android:textColor="#7E89B0"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <include android:id="@+id/profile_help" layout="@layout/item_help_center" />
                <include android:id="@+id/profile_contact" layout="@layout/item_contact_support" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="32dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend_medium"
                        android:letterSpacing="0.15"
                        android:text="TEACHSYNC FOR TEACHERS"
                        android:textAllCaps="true"
                        android:textColor="#5C6A95"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Version 1.0.0 • Made with precision"
                        android:textSize="11sp"
                        android:textColor="#7E89B0"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>
    </LinearLayout>
</FrameLayout>