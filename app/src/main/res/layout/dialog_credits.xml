<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@mipmap/ic_launcher"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TeachSync"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="@font/lexend_bold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Version 1.0.0"
        android:textColor="#9AA4C7"
        android:textSize="14sp"
        android:layout_marginBottom="24dp"
        android:fontFamily="@font/lexend"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Developed by"
        android:textColor="#7E89B0"
        android:textSize="12sp"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/lexend"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Intisar Muhib"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginBottom="4dp"
        android:fontFamily="@font/lexend_medium"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Special thanks to the TeachSync community"
        android:textColor="#9AA4C7"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/lexend"/>

    <Button
        android:id="@+id/btnCreditsClose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Close"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:backgroundTint="#5667FF"
        app:cornerRadius="12dp"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

</LinearLayout>