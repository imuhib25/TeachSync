<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#0B1023"
    tools:context=".DashboardFragment">

    <!-- Scroll Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Welcome Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:id="@+id/profile_pic"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:contentDescription="Profile Picture"
                    android:src="@drawable/baseline_account_circle_24"
                    android:scaleType="centerCrop"
                    android:background="@drawable/circle_bg"
                    android:padding="2dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome back,"
                        android:textColor="#A0A8C0"
                        android:textSize="13sp"
                        android:fontFamily="@font/lexend"/>

                    <TextView
                        android:id="@+id/welcome_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jane Doe"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/lexend_bold"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/btn_notifications"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/circle_bg"
                    android:padding="11dp"
                    android:src="@drawable/outline_notifications_24"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="#FFFFFF" />

                <ImageView
                    android:id="@+id/btn_info"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/circle_bg"
                    android:padding="11dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/baseline_info_24"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="#FFFFFF" />
            </LinearLayout>

            <!-- Top Cards Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="20dp">

                <!-- Total Students Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#1A2140"
                    app:strokeWidth="1dp"
                    app:strokeColor="#26304D">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp"
                        android:orientation="vertical"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Students"
                            android:textColor="#DADFFF"
                            android:textSize="13sp"
                            android:fontFamily="@font/lexend"/>

                        <TextView
                            android:id="@+id/tvTotalStudents"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/lexend_bold"/>

                        <TextView
                            android:id="@+id/tvTotalStudentsMonth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+0 this month"
                            android:textColor="#00E676"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/lexend"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Today's Classes Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#1A2140"
                    app:strokeWidth="1dp"
                    app:strokeColor="#26304D">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp"
                        android:orientation="vertical"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Today's Classes"
                            android:textColor="#AAB2FF"
                            android:textSize="13sp"
                            android:fontFamily="@font/lexend"/>

                        <TextView
                            android:id="@+id/tvTodayClasses"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/lexend_bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Keep it up!"
                            android:textColor="#7F8CFF"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/lexend"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Monthly Earnings Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="22dp"
                app:cardBackgroundColor="#1A2140"
                app:strokeWidth="1dp"
                app:strokeColor="#26304D"
                android:layout_marginBottom="24dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/lblMonthlyEarnings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MONTHLY EARNINGS"
                        android:textColor="#8F9BFF"
                        android:textSize="12sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="@font/lexend_bold"/>

                    <TextView
                        android:id="@+id/tvMonthlyEarnings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/lblMonthlyEarnings"
                        android:text="৳0"
                        android:textColor="#FFFFFF"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/lexend_bold"/>

                    <TextView
                        android:id="@+id/tvMonthlyTarget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_alignBaseline="@id/tvMonthlyEarnings"
                        android:text="Target: ৳0"
                        android:textColor="#A0A8C0"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend"/>

                    <ProgressBar
                        android:id="@+id/progressMonthlyEarnings"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_below="@id/tvMonthlyEarnings"
                        android:progress="0"
                        android:max="100"
                        android:layout_marginTop="16dp"
                        android:progressTint="#5667FF"
                        android:backgroundTint="#10152C"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <include
                layout="@layout/layout_ad_placeholder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp" />

            <!-- Recent Activity Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recent Activity"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/lexend_bold"/>

                <TextView
                    android:id="@+id/btn_clear_activity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear All"
                    android:textColor="#FF5A5A"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/lexend_medium"
                    android:padding="4dp"/>
            </LinearLayout>

            <!-- Recent Activity RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerRecentActivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"/>

        </LinearLayout>
    </ScrollView>

</FrameLayout>